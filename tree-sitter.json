{
  "grammars": [
    {
      "name": "procman",
      "camelcase": "Procman",
      "scope": "source.procman",
      "path": ".",
      "file-types": [
        "pman"
      ],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm",
      "injection-regex": "^(procman|pman)$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Procman (.pman) grammar for tree-sitter",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-procman"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
